generator client {
  provider = "prisma-client-js"
  // Remova a linha 'url' daqui
}

datasource db {
  provider = "postgresql"
}

model Order {
  orderId      String   @id
  value        Float
  creationDate DateTime
  items        Item[]
}

model Item {
  id        Int    @id @default(autoincrement())
  productId Int
  quantity  Int
  price     Float
  orderId   String
  order     Order  @relation(fields: [orderId], references: [orderId])
}